{
  "name": "macro-syntax-highlighter",
  "displayName": "Macro Syntax Highlighter",
  "description": "Adds syntax highlighting for .macro files",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "macro",
        "aliases": [
          "Macro",
          "macro"
        ],
        "extensions": [
          ".macro"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "macro",
        "scopeName": "source.macro",
        "path": "./syntaxes/macro.tmLanguage.json"
      }
    ]
  }
}
